{
  "title": "HOG Fashion - Simplified Offer Negotiation with Mutual Consent",
  "version": "2.0",
  "lastUpdated": "2026-01-03",
  "overview": {
    "description": "A WhatsApp-style chat-based offer negotiation system where buyers and vendors can seamlessly negotiate prices. Both parties must provide consent before payment can proceed.",
    "keyFeatures": [
      "Chat-style negotiation interface",
      "Three simple actions: Accept, Reject, Negotiate (Counter)",
      "Mutual consent requirement - both parties must agree before payment",
      "Seamless integration with existing review and payment systems",
      "Real-time status tracking for both parties"
    ]
  },

  "workFlow": {
    "step1": {
      "title": "Vendor Creates Quote (Review)",
      "description": "Vendor creates initial quote for buyer's material",
      "endpoint": "POST /api/v1/review/createReview/:materialId",
      "result": "Review created with initial costs in NGN (and USD if international vendor)"
    },
    "step2": {
      "title": "Buyer Initiates Negotiation (Optional)",
      "description": "Buyer can either pay directly OR start negotiation",
      "endpoint": "POST /api/v1/makeOffer/createMakeOffer/:reviewId",
      "action": "Buyer proposes counter amounts",
      "result": "Offer created with status 'incoming', waiting for vendor response"
    },
    "step3": {
      "title": "Vendor Responds to Offer",
      "description": "Vendor can Accept, Reject, or Counter the buyer's offer",
      "endpoint": "POST /api/v1/makeOffer/vendorReplyOffer/:offerId",
      "actions": {
        "accept": {
          "description": "Vendor accepts buyer's offer",
          "result": "vendorConsent = true, waiting for buyer to confirm",
          "message": "Offer accepted successfully. Waiting for buyer to confirm consent."
        },
        "reject": {
          "description": "Vendor rejects the offer",
          "result": "Offer status = rejected, negotiation ends",
          "message": "Offer rejected successfully"
        },
        "counter": {
          "description": "Vendor proposes different amounts",
          "result": "New counter offer sent, consents reset, waiting for buyer",
          "message": "Counter offer sent successfully"
        }
      }
    },
    "step4": {
      "title": "Buyer Responds to Vendor's Reply",
      "description": "Buyer can Accept, Reject, or Counter the vendor's response",
      "endpoint": "POST /api/v1/makeOffer/buyerReplyToOffer/:offerId",
      "actions": {
        "accept": {
          "description": "Buyer accepts vendor's counter or confirms vendor's acceptance",
          "result": "buyerConsent = true, if vendor already consented → mutualConsentAchieved = true",
          "messages": {
            "mutualConsent": "Offer accepted successfully. Both parties have consented. You can now proceed to payment.",
            "waitingForVendor": "Offer accepted successfully. Waiting for vendor to confirm consent."
          }
        },
        "reject": {
          "description": "Buyer rejects the vendor's counter",
          "result": "Offer status = rejected, negotiation ends",
          "message": "You rejected the vendor's offer successfully"
        },
        "counter": {
          "description": "Buyer proposes new amounts",
          "result": "New counter offer sent, consents reset, waiting for vendor",
          "message": "Counter offer sent successfully"
        }
      }
    },
    "step5": {
      "title": "Mutual Consent Achieved",
      "description": "When both parties accept, mutual consent is achieved",
      "conditions": [
        "buyerConsent = true",
        "vendorConsent = true",
        "mutualConsentAchieved = true"
      ],
      "result": "Review is updated with final agreed amounts, payment can proceed"
    },
    "step6": {
      "title": "Payment",
      "description": "Buyer proceeds to payment (only allowed with mutual consent OR no negotiation)",
      "endpoints": {
        "stripe": "POST /api/v1/stripe/make-payment/:reviewId (International vendors)",
        "paystack": "POST /api/v1/material/createPaymentOnline/:reviewId (Nigerian vendors)"
      },
      "validation": "If offer exists, mutualConsentAchieved must be true"
    }
  },

  "updatedOfferModel": {
    "modelName": "MakeOffer",
    "fields": {
      "userId": {
        "type": "ObjectId",
        "ref": "User",
        "description": "The buyer who created the offer"
      },
      "vendorId": {
        "type": "ObjectId",
        "ref": "Vendor",
        "description": "The vendor receiving the offer"
      },
      "materialId": {
        "type": "ObjectId",
        "ref": "Material",
        "description": "The material being quoted"
      },
      "reviewId": {
        "type": "ObjectId",
        "ref": "Review",
        "description": "The associated review/quote"
      },
      "status": {
        "type": "String",
        "enum": ["pending", "accepted", "rejected", "countered", "incoming"],
        "description": "Current offer status for quick filtering"
      },
      "buyerConsent": {
        "type": "Boolean",
        "default": false,
        "description": "NEW: Has the buyer consented to the current offer?"
      },
      "vendorConsent": {
        "type": "Boolean",
        "default": false,
        "description": "NEW: Has the vendor consented to the current offer?"
      },
      "mutualConsentAchieved": {
        "type": "Boolean",
        "default": false,
        "description": "NEW: Have both parties consented? Required for payment"
      },
      "finalMaterialCost": {
        "type": "Number",
        "default": 0,
        "description": "NEW: Final agreed material cost in NGN"
      },
      "finalWorkmanshipCost": {
        "type": "Number",
        "default": 0,
        "description": "NEW: Final agreed workmanship cost in NGN"
      },
      "finalTotalCost": {
        "type": "Number",
        "default": 0,
        "description": "NEW: Final agreed total cost in NGN"
      },
      "chats": {
        "type": "Array",
        "description": "WhatsApp-style message history",
        "structure": {
          "senderType": {
            "type": "String",
            "enum": ["customer", "vendor"],
            "description": "Who sent this message"
          },
          "action": {
            "type": "String",
            "enum": ["accepted", "rejected", "countered", "pending", "incoming"],
            "description": "What action was taken"
          },
          "counterMaterialCost": {
            "type": "Number",
            "description": "Proposed material cost in NGN"
          },
          "counterWorkmanshipCost": {
            "type": "Number",
            "description": "Proposed workmanship cost in NGN"
          },
          "counterTotalCost": {
            "type": "Number",
            "description": "Proposed total cost in NGN"
          },
          "comment": {
            "type": "String",
            "description": "Optional message from sender"
          },
          "timestamp": {
            "type": "Date",
            "description": "When this message was sent"
          }
        }
      }
    }
  },

  "apiEndpoints": {
