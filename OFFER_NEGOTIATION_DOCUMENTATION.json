  },

  "keyChanges": {
    "modelChanges": [
      "Added buyerConsent (Boolean)",
      "Added vendorConsent (Boolean)",
      "Added mutualConsentAchieved (Boolean)",
      "Added finalMaterialCost, finalWorkmanshipCost, finalTotalCost (Numbers)"
    ],
    "behaviorChanges": [
      "When vendor accepts → sets vendorConsent=true, waits for buyer",
      "When buyer accepts → sets buyerConsent=true, waits for vendor",
      "When both consent → mutualConsentAchieved=true, Review updated",
      "Any counter offer → resets all consents to false",
      "Rejection → resets all consents to false, ends negotiation",
      "Payment requires mutualConsentAchieved=true if offer exists"
    ],
    "apiResponseChanges": [
      "All offer responses now include buyerConsent, vendorConsent, mutualConsentAchieved",
      "Success messages indicate consent status",
      "Payment endpoints return detailed consent error if validation fails"
    ]
  },

  "testingChecklist": [
    "✓ Buyer creates offer → status=incoming, consents=false",
    "✓ Vendor accepts → vendorConsent=true, waiting for buyer",
    "✓ Buyer confirms → mutualConsentAchieved=true, Review updated",
    "✓ Payment succeeds with mutual consent",
    "✓ Payment blocked without mutual consent",
    "✓ Counter offer resets consents",
    "✓ Multiple back-and-forth counters work correctly",
    "✓ Rejection ends negotiation",
    "✓ Payment without negotiation works",
    "✓ International vendor USD conversion works with negotiated amounts",
    "✓ Chat history displays in correct order",
    "✓ Final amounts stored correctly when mutual consent achieved"
  ]
}
