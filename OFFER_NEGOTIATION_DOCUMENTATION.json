      "description": "Buyer creates or updates an offer for a review",
      "headers": {
        "Authorization": "Bearer {token}",
        "Content-Type": "application/json"
      },
      "requestBody": {
        "materialTotalCost": 45000,
        "workmanshipTotalCost": 30000,
        "comment": "Can we reduce the price a bit?"
      },
      "responseSuccess": {
        "success": true,
        "message": "Offer created successfully",
        "data": {
          "_id": "offer123",
          "userId": "buyer123",
          "vendorId": "vendor123",
          "reviewId": "review123",
          "status": "incoming",
          "buyerConsent": false,
          "vendorConsent": false,
          "mutualConsentAchieved": false,
          "finalMaterialCost": 0,
          "finalWorkmanshipCost": 0,
          "finalTotalCost": 0,
          "chats": [
            {
              "senderType": "customer",
              "action": "incoming",
              "counterMaterialCost": 45000,
              "counterWorkmanshipCost": 30000,
              "counterTotalCost": 75000,
              "comment": "Can we reduce the price a bit?",
              "timestamp": "2026-01-03T10:00:00Z"
