  "paymentValidation": {
    "description": "Payment endpoints now validate mutual consent before processing",
    "stripeEndpoint": "POST /api/v1/stripe/make-payment/:reviewId",
    "paystackEndpoint": "POST /api/v1/material/createPaymentOnline/:reviewId",
    "validation": {
      "noNegotiation": {
        "condition": "review.hasAcceptedOffer = false OR review.acceptedOfferId is null",
        "result": "Payment proceeds with original quote amounts"
      },
      "withNegotiation": {
        "condition": "review.hasAcceptedOffer = true AND review.acceptedOfferId exists",
        "requirements": [
          "Fetch the offer by acceptedOfferId",
          "Check offer.mutualConsentAchieved = true",
          "If not true, reject payment"
        ],
        "errorResponse": {
          "success": false,
          "message": "Payment cannot proceed. Both buyer and vendor must consent to the negotiated offer before payment.",
          "requiresMutualConsent": true,
          "buyerConsent": false,
          "vendorConsent": true,
          "offerId": "offer123"
        }
      }
    }
  },

