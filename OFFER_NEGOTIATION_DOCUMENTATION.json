          "step": 1,
          "actor": "Buyer",
          "action": "Creates offer with ₦75,000",
          "result": "status=incoming, buyerConsent=false, vendorConsent=false"
        },
        {
          "step": 2,
          "actor": "Vendor",
          "action": "Accepts the offer (action=accepted)",
          "result": "status=accepted, buyerConsent=false, vendorConsent=true, message='Waiting for buyer to confirm'"
        },
        {
          "step": 3,
          "actor": "Buyer",
          "action": "Confirms acceptance (action=accepted)",
          "result": "status=accepted, buyerConsent=true, vendorConsent=true, mutualConsentAchieved=true, Review updated, message='Both parties consented, proceed to payment'"
        },
        {
          "step": 4,
          "actor": "Buyer",
          "action": "Makes payment",
          "result": "Payment succeeds, money transferred"
        }
      ]
    },

